<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ScanAndSave.Converters"
             x:Class="ScanAndSave.Views.GroupsPage"
             Title="Mine grupper"
             BackgroundColor="{StaticResource BackgroundLight}">

    <ContentPage.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ========== HEADER ========== -->
        <Grid Grid.Row="0"
              Padding="20,16,20,12"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label Text="Mine grupper"
                       Style="{StaticResource PageTitle}"/>
                <Label Text="Vælg en gruppe for at se varer"
                       Style="{StaticResource PageSubtitle}"/>
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="+ Ny"
                    Style="{StaticResource PrimaryButton}"
                    FontSize="14"
                    WidthRequest="86"
                    HeightRequest="44"
                    CornerRadius="10"
                    Padding="0"
                    Clicked="OnAddGroup"
                    VerticalOptions="Center"/>
        </Grid>

        <!-- ========== LOADING INDIKATOR ========== -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{StaticResource Primary}"
                           HeightRequest="30"
                           Margin="0,4"/>

        <!-- ========== GRUPPER LISTE ========== -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Groups}"
                        Margin="20,4,20,20"
                        SelectionMode="None">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>

            <!-- Tom tilstand -->
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="10"
                                     Padding="24">
                    <Label Text="🗂"
                           FontSize="48"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Ingen grupper endnu"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Opret din første gruppe, fx 'Køleskab' eller 'Fryser'"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center"/>
                    <Button Text="Opret gruppe"
                            Style="{StaticResource PrimaryButton}"
                            WidthRequest="200"
                            Clicked="OnAddGroup"
                            HorizontalOptions="Center"
                            Margin="0,8,0,0"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Slet"
                                           BackgroundColor="{StaticResource Danger}"
                                           Invoked="OnDeleteGroup"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Style="{StaticResource CardFrame}"
                               Padding="0"
                               IsClippedToBounds="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGroupTapped"
                                                      CommandParameter="{Binding .}"/>
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="84,*,Auto" HeightRequest="84">

                                <!-- Gruppe-billede eller placeholder -->
                                <Grid BackgroundColor="{StaticResource PrimaryLight}"
                                      WidthRequest="84">
                                    <!-- Vis billede hvis det findes -->
                                    <Image Source="{Binding ImagePath}"
                                           Aspect="AspectFill"
                                           IsVisible="{Binding ImagePath, Converter={StaticResource BoolToVis}}"
                                           WidthRequest="84"
                                           HeightRequest="84"/>
                                    <!-- Placeholder ikon -->
                                    <Label Text="📦"
                                           FontSize="32"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           IsVisible="{Binding ImagePath, Converter={StaticResource InverseBool}}"/>
                                </Grid>

                                <!-- Gruppe info -->
                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center"
                                                     Padding="14,0"
                                                     Spacing="2">
                                    <Label Text="{Binding Name}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding CreatedAt, StringFormat='Oprettet {0:dd/MM/yyyy}'}"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"/>
                                </VerticalStackLayout>

                                <!-- Pil -->
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}"
                                       VerticalOptions="Center"
                                       Margin="0,0,18,0"/>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
