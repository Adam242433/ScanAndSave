<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:converters="clr-namespace:ScanAndSave.Converters"
             x:Class="ScanAndSave.Views.ScannerPage"
             Title="Scan &amp; Save"
             BackgroundColor="{StaticResource BackgroundLight}">

    <ContentPage.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:StringToBoolConverter x:Key="StringToBool"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ========== HEADER ========== -->
        <Grid Grid.Row="0"
              Padding="20,16,20,12"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label Text="Scan &amp; Save"
                       Style="{StaticResource PageTitle}"/>
                <Label Text="Scan en stregkode for at tilføje en vare"
                       Style="{StaticResource PageSubtitle}"/>
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="Mine grupper"
                    Style="{StaticResource SecondaryButton}"
                    Clicked="OnGroupsClicked"
                    VerticalOptions="Center"/>
        </Grid>

        <!-- ========== SCROLLABLE CONTENT ========== -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="14" Padding="20,0,20,24">

                <!-- ===== KAMERA SCANNER ===== -->
                <Frame Style="{StaticResource CardFrame}"
                       Padding="0"
                       IsClippedToBounds="True">
                    <Grid HeightRequest="290">
                        <!-- ZXing kamera-scanner -->
                        <zxing:CameraBarcodeReaderView
                            x:Name="BarcodeReader"
                            IsDetecting="True"
                            BarcodesDetected="OnBarcodesDetected"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"/>

                        <!-- Sigte-ramme -->
                        <Border Stroke="White"
                                StrokeThickness="3"
                                StrokeShape="RoundRectangle 16"
                                BackgroundColor="Transparent"
                                WidthRequest="220"
                                HeightRequest="140"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Opacity="0.85"/>

                        <!-- Scanning-indikator-tekst -->
                        <Frame BackgroundColor="#B3000000"
                               CornerRadius="20"
                               Padding="14,8"
                               HasShadow="False"
                               BorderColor="Transparent"
                               HorizontalOptions="Center"
                               VerticalOptions="End"
                               Margin="0,0,0,16">
                            <Label Text="Hold stregkoden i rammen"
                                   TextColor="White"
                                   FontSize="13"
                                   HorizontalTextAlignment="Center"/>
                        </Frame>
                    </Grid>
                </Frame>

                <!-- ===== SCANNET STREGKODE BADGE ===== -->
                <Frame Style="{StaticResource CardFrame}"
                       Padding="14"
                       IsVisible="{Binding HasScannedBarcode}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Frame BackgroundColor="{StaticResource Accent}"
                               CornerRadius="8"
                               Padding="10,6"
                               HasShadow="False"
                               BorderColor="Transparent"
                               VerticalOptions="Center">
                            <Label Text="SCANNET"
                                   TextColor="White"
                                   FontSize="11"
                                   FontAttributes="Bold"/>
                        </Frame>
                        <Label Grid.Column="1"
                               Text="{Binding ScannedBarcode}"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center"
                               LineBreakMode="MiddleTruncation"/>
                        <Button Grid.Column="2"
                                Text="Ryd"
                                TextColor="{StaticResource TextSecondary}"
                                BackgroundColor="Transparent"
                                FontSize="13"
                                Padding="8,0"
                                HeightRequest="36"
                                MinimumWidthRequest="0"
                                Clicked="OnClearBarcode"
                                VerticalOptions="Center"/>
                    </Grid>
                </Frame>

                <!-- ===== TILFØJ VARE FORMULAR ===== -->
                <Frame Style="{StaticResource CardFrame}"
                       IsVisible="{Binding HasScannedBarcode}">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Tilføj vare"
                               Style="{StaticResource SectionTitle}"/>

                        <!-- Varenavn -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Varenavn" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Placeholder="Fx Arla Letmælk 1L"
                                       Text="{Binding ProductName}"
                                       Style="{StaticResource EntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Kategori -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Kategori" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Placeholder="Fx Mejeri, Kød, Drikkevarer"
                                       Text="{Binding Category}"
                                       Style="{StaticResource EntryStyle}"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Antal -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Antal" Style="{StaticResource FieldLabel}"/>
                            <Grid ColumnDefinitions="52,*,52"
                                  ColumnSpacing="10"
                                  HeightRequest="48">
                                <Button Text="−"
                                        Style="{StaticResource StepperMinusButton}"
                                        Clicked="OnQuantityMinus"/>
                                <Border Grid.Column="1"
                                        Style="{StaticResource FieldBorder}"
                                        Padding="0">
                                    <Label Text="{Binding Quantity}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Text="+"
                                        Style="{StaticResource StepperPlusButton}"
                                        Clicked="OnQuantityPlus"/>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Udløbsdato -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Udløbsdato (valgfrit)" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <DatePicker x:Name="ExpiryPicker"
                                            Format="dd/MM/yyyy"
                                            Style="{StaticResource DatePickerStyle}"
                                            DateSelected="OnExpiryDateSelected"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Gruppe-vælger -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Opbevaringsgruppe" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Picker x:Name="GroupPicker"
                                        Title="Vælg gruppe..."
                                        ItemsSource="{Binding AvailableGroups}"
                                        ItemDisplayBinding="{Binding Name}"
                                        Style="{StaticResource PickerStyle}"
                                        SelectedIndexChanged="OnGroupSelected"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Bemærkninger -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Bemærkninger (valgfrit)" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}"
                                    Padding="12,8"
                                    MinimumHeightRequest="80">
                                <Editor Placeholder="Tilføj noter..."
                                        Text="{Binding Notes}"
                                        HeightRequest="80"
                                        Style="{StaticResource EditorStyle}"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Status besked -->
                        <Label Text="{Binding StatusMessage}"
                               TextColor="{StaticResource Accent}"
                               FontSize="14"
                               FontAttributes="Bold"
                               IsVisible="{Binding StatusMessage, Converter={StaticResource StringToBool}}"
                               HorizontalTextAlignment="Center"/>

                        <!-- Tilføj-knap -->
                        <Button Text="Tilføj vare"
                                Style="{StaticResource PrimaryButton}"
                                Clicked="OnAddProduct"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                                Margin="0,4,0,0"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- ===== HURTIG-ADGANG TIL GRUPPER (før scan) ===== -->
                <Frame Style="{StaticResource CardFrame}"
                       IsVisible="{Binding HasScannedBarcode, Converter={StaticResource InverseBool}}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Dine grupper"
                               Style="{StaticResource SectionTitle}"/>
                        <Label Text="Tryk 'Mine grupper' for at se dine opbevaringssteder"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"/>
                        <Button Text="Se alle grupper"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnGroupsClicked"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
